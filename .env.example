# ── UDBHAV'26 Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git (it's already in .gitignore).

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/udbhav26?retryWrites=true&w=majority

# Cashfree Payment Gateway keys
# Create an account at https://cashfree.com → Developers → API Keys
# Use TEST keys for sandbox, PROD keys for live
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key

# Pusher (real-time PS slot updates) — create a free app at https://pusher.com
PUSHER_APP_ID=xxxxxxx

PUSHER_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
PUSHER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
PUSHER_CLUSTER=ap2

# Admin secret — used to authenticate admin PS management endpoints.
# Set a strong random string (e.g. openssl rand -hex 32)
ADMIN_SECRET=change_me_to_a_strong_random_secret

# Cloudinary Setup for Payment Screenshots
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=